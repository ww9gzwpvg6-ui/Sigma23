-- دالة نسخ السكن بالتثبيت القوي
local function ApplyAvatar(username, isSilent)
    if not isSilent then AvatarLogEvent:Fire("Searching for user...", Color3.fromRGB(255, 255, 100)) end
    task.spawn(function()
        local success, userId = pcall(function()
            return Players:GetUserIdFromNameAsync(username)
        end)
        if not success or not userId then
            if not isSilent then AvatarLogEvent:Fire("Error: Player not found!", Color3.fromRGB(255, 100, 100)) end
            return
        end
        
        if not isSilent then AvatarLogEvent:Fire("Downloading avatar assets...", Color3.fromRGB(255, 255, 100)) end
        
        local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
        
        local appearanceSuccess, appearance = pcall(function()
            return Players:GetCharacterAppearanceAsync(userId)
        end)
        
        if not appearanceSuccess or not appearance then
            if not isSilent then AvatarLogEvent:Fire("Error: Failed to load appearance!", Color3.fromRGB(255, 100, 100)) end
            return
        end
        
        if not isSilent then AvatarLogEvent:Fire("Applying and welding items...", Color3.fromRGB(255, 255, 100)) end
        
        for _, v in pairs(char:GetChildren()) do
            if v:IsA("Accessory") or v:IsA("Hat") or v:IsA("Shirt") or v:IsA("Pants") or v:IsA("CharacterMesh") or v:IsA("ShirtGraphic") or v:IsA("BodyColors") or v.Name:match("^CustomHat_") then
                v:Destroy()
            end
            if v:IsA("Part") and v.Name == "Head" then
                local face = v:FindFirstChildOfClass("Decal")
                if face then face:Destroy() end
            end
        end
        
        task.wait(0.1)
        
        for _, item in pairs(appearance:GetChildren()) do
            if item:IsA("Accessory") or item:IsA("Hat") then
                local handle = item:FindFirstChild("Handle")
                if handle then
                    local clonedHandle = handle:Clone()
                    clonedHandle.Name = "CustomHat_" .. item.Name
                    clonedHandle.CanCollide = false
                    clonedHandle.Massless = true
                    clonedHandle.Parent = char
                    
                    local att = handle:FindFirstChildOfClass("Attachment")
                    local charAtt = nil
                    if att then
                        for _, v in pairs(char:GetDescendants()) do
                            if v:IsA("Attachment") and v.Name == att.Name then
                                charAtt = v
                                break
                            end
                        end
                    end
                    
                    local weld = Instance.new("Weld")
                    weld.Name = "ForceWeld"
                    weld.Part1 = clonedHandle
                    if charAtt then
                        weld.Part0 = charAtt.Parent
                        weld.C0 = charAtt.CFrame
                        weld.C1 = att.CFrame
                    else
                        local head = char:FindFirstChild("Head")
                        if head then
                            weld.Part0 = head
                            weld.C0 = CFrame.new(0, 0.5, 0)
                        end
                    end
                    weld.Parent = clonedHandle
                end
            elseif item:IsA("Shirt") or item:IsA("Pants") or item:IsA("CharacterMesh") or item:IsA("BodyColors") or item:IsA("ShirtGraphic") then
                item.Parent = char
            elseif item:IsA("Decal") and item.Name == "face" then
                local head = char:FindFirstChild("Head")
                if head then item.Parent = head end
            end
        end
        
        if not isSilent then AvatarLogEvent:Fire("Success: Avatar forcefully applied locally!", Color3.fromRGB(0, 255, 120)) end
    end)
end

-- دالة الاسترجاع مع التثبيت القوي لإكسسواراتك الأصلية وتخطي حماية اللعبة
local function ResetAvatar()
    AvatarLogEvent:Fire("Reverting to original avatar...", Color3.fromRGB(255, 255, 100))
    task.spawn(function()
        local char = LocalPlayer.Character
        if not char then return end
        
        local success, appearance = pcall(function()
            return Players:GetCharacterAppearanceAsync(LocalPlayer.UserId)
        end)
        
        if success and appearance then
            for _, v in pairs(char:GetChildren()) do
                if v:IsA("Accessory") or v:IsA("Hat") or v:IsA("Shirt") or v:IsA("Pants") or v:IsA("CharacterMesh") or v:IsA("ShirtGraphic") or v:IsA("BodyColors") or v.Name:match("^CustomHat_") then
                    v:Destroy()
                end
                if v:IsA("Part") and v.Name == "Head" then
                    local face = v:FindFirstChildOfClass("Decal")
                    if face then face:Destroy() end
                end
            end
            task.wait(0.1)
            
            -- إعادة تركيب قبعاتك وشعرك الأصلي بنظام التلحيم القوي لحمايتها من الحذف
            for _, item in pairs(appearance:GetChildren()) do
                if item:IsA("Accessory") or item:IsA("Hat") then
                    local handle = item:FindFirstChild("Handle")
                    if handle then
                        local clonedHandle = handle:Clone()
                        clonedHandle.Name = "CustomHat_" .. item.Name
                        clonedHandle.CanCollide = false
                        clonedHandle.Massless = true
                        clonedHandle.Parent = char
                        
                        local att = handle:FindFirstChildOfClass("Attachment")
                        local charAtt = nil
                        if att then
                            for _, v in pairs(char:GetDescendants()) do
                                if v:IsA("Attachment") and v.Name == att.Name then
                                    charAtt = v
                                    break
                                end
                            end
                        end
                        
                        local weld = Instance.new("Weld")
                        weld.Name = "ForceWeld"
                        weld.Part1 = clonedHandle
                        if charAtt then
                            weld.Part0 = charAtt.Parent
                            weld.C0 = charAtt.CFrame
                            weld.C1 = att.CFrame
                        else
                            local head = char:FindFirstChild("Head")
                            if head then
                                weld.Part0 = head
                                weld.C0 = CFrame.new(0, 0.5, 0)
                            end
                        end
                        weld.Parent = clonedHandle
                    end
                elseif item:IsA("Shirt") or item:IsA("Pants") or item:IsA("CharacterMesh") or item:IsA("BodyColors") or item:IsA("ShirtGraphic") then
                    item.Parent = char
                elseif item:IsA("Decal") and item.Name == "face" then
                    local head = char:FindFirstChild("Head")
                    if head then item.Parent = head end
                end
            end
            AvatarLogEvent:Fire("Success: Reverted to normal!", Color3.fromRGB(0, 255, 120))
        else
            AvatarLogEvent:Fire("Error: Failed to revert!", Color3.fromRGB(255, 100, 100))
        end
    end)
end

