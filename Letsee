local function SaveConfig()
    if writefile then
        pcall(function()
            local ConfigsToSave = {}
            for k, v in pairs(Configs) do
                if k ~= "Air Dribble" then ConfigsToSave[k] = v end
            end
            local dataToSave = { Configs = ConfigsToSave, GlobalData = GlobalData }
            writefile("Tolhub_Data_V5.json", HttpService:JSONEncode(dataToSave))
        end)
    end
end

local function LoadConfig()
    if readfile and isfile and isfile("Tolhub_Data_V5.json") then
        pcall(function()
            local decoded = HttpService:JSONDecode(readfile("Tolhub_Data_V5.json"))
            if decoded.Configs then
                for k, v in pairs(decoded.Configs) do
                    if Configs[k] and k ~= "Air Dribble" then
                        if k == "Avatar" then
                            Configs.Avatar.Auto = v.Auto or false
                            Configs.Avatar.Username = v.Username or ""
                        else
                            Configs[k].Enabled = v.Enabled
                            Configs[k].Value = v.Value
                        end
                    end
                end
            end
            if decoded.GlobalData then
                GlobalData.MaxLimit = decoded.GlobalData.MaxLimit
                GlobalData.LimitEndTime = decoded.GlobalData.LimitEndTime
                GlobalData.CodeUsed = decoded.GlobalData.CodeUsed
            end
        end)
    end
end

