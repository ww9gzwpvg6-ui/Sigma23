        local function UpdateText()
            local displayVal = Configs[name].Value
            InfoLabel.Text = name .. (name == "Air Dribble" and " Size: " or ": ") .. displayVal .. " | " .. (Configs[name].Enabled and "ON" or "OFF")
        end
        UpdateText()

        local ToggleBtn = Instance.new("TextButton", Page)
        ToggleBtn.Size = UDim2.new(0.95, 0, 0, 40)
        ToggleBtn.Position = UDim2.new(0, 0, 0, 55)
        ToggleBtn.Text = name .. ": " .. (Configs[name].Enabled and "ENABLED" or "DISABLED")
        ToggleBtn.Font = Enum.Font.GothamBold
        ToggleBtn.TextSize = 13
        ToggleBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
        ToggleBtn.BackgroundColor3 = Configs[name].Enabled and Color3.fromRGB(0, 170, 255) or Color3.fromRGB(40, 40, 45)
        ToggleBtn.BackgroundTransparency = 0.3
        Instance.new("UICorner", ToggleBtn).CornerRadius = UDim.new(0, 8)

        ToggleBtn.MouseButton1Click:Connect(function()
            Configs[name].Enabled = not Configs[name].Enabled
            ToggleBtn.Text = name .. ": " .. (Configs[name].Enabled and "ENABLED" or "DISABLED")
            ToggleBtn.BackgroundColor3 = Configs[name].Enabled and Color3.fromRGB(0, 170, 255) or Color3.fromRGB(40, 40, 45)
            InfoLabel.TextColor3 = Configs[name].Enabled and Color3.fromRGB(0, 255, 120) or Color3.fromRGB(255, 100, 100)
            UpdateText()
            SaveConfig()
        end)

        local ControlFrame = Instance.new("Frame", Page)
        ControlFrame.Position = UDim2.new(0, 0, 0, 115)
        ControlFrame.Size = UDim2.new(0.95, 0, 0, 45)
        ControlFrame.BackgroundTransparency = 1

        local MinusBtn = Instance.new("TextButton", ControlFrame)
        MinusBtn.Size = UDim2.new(0, 55, 0, 45)
        MinusBtn.Position = UDim2.new(0.5, -60, 0, 0)
        MinusBtn.Text = "-"
        MinusBtn.Font = Enum.Font.GothamBold
        MinusBtn.TextSize = 26
        MinusBtn.TextColor3 = Color3.fromRGB(20, 20, 20)
        MinusBtn.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
        Instance.new("UICorner", MinusBtn).CornerRadius = UDim.new(0, 10)

        local PlusBtn = Instance.new("TextButton", ControlFrame)
        PlusBtn.Size = UDim2.new(0, 55, 0, 45)
        PlusBtn.Position = UDim2.new(0.5, 5, 0, 0)
        PlusBtn.Text = "+"
        PlusBtn.Font = Enum.Font.GothamBold
        PlusBtn.TextSize = 26
        PlusBtn.TextColor3 = Color3.fromRGB(20, 20, 20)
        PlusBtn.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
        Instance.new("UICorner", PlusBtn).CornerRadius = UDim.new(0, 10)

        MinusBtn.MouseButton1Click:Connect(function()
            if Configs[name].Value > 0 then
                Configs[name].Value = Configs[name].Value - 1
                UpdateText()
                SaveConfig()
            end
        end)

        PlusBtn.MouseButton1Click:Connect(function()
            if Configs[name].Value < GlobalData.MaxLimit then
                Configs[name].Value = Configs[name].Value + 1
                UpdateText()
                SaveConfig()
            end
        end)
    end

    Btn.MouseButton1Click:Connect(function()
        for _, p in pairs(Pages) do p.Visible = false end
        for _, b in pairs(TabButtons) do 
            b.BackgroundColor3 = Color3.fromRGB(25, 25, 30)
            b.TextColor3 = Color3.fromRGB(180, 180, 180) 
        end
        Page.Visible = true
        Btn.BackgroundColor3 = Color3.fromRGB(0, 170, 255)
        Btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    end)
    
    if index == 1 then
        Btn.BackgroundColor3 = Color3.fromRGB(0, 170, 255)
        Btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    end
end

for i, tabName in ipairs(Tabs) do
    CreatePage(tabName, i)
end

-- [ نظام الريتش السريع للمراوغة (بدون كول داون + دبل تاتش) ] --
local function GetLeg(char, hum, pref)
    if hum.RigType == Enum.HumanoidRigType.R6 then
        return pref == 1 and char:FindFirstChild("Right Leg") or char:FindFirstChild("Left Leg")
    else
        return pref == 1 and char:FindFirstChild("RightLowerLeg") or char:FindFirstChild("LeftLowerLeg")
    end
end

RunService.RenderStepped:Connect(function()
    local char = LocalPlayer.Character
    if not char then return end
    
    local hum = char:FindFirstChildOfClass("Humanoid")
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hum or not hrp then return end

    local tpSystem = workspace:FindFirstChild("TPSSystem")
    local tps = tpSystem and tpSystem:FindFirstChild("TPS")
    if not tps then return end

    local prefFootFolder = Lighting:FindFirstChild(LocalPlayer.Name)
    local prefFoot = prefFootFolder and prefFootFolder:FindFirstChild("PreferredFoot")
    if not prefFoot then return end

    local foot = GetLeg(char, hum, prefFoot.Value)
    if not foot then return end

    local mag = (hrp.Position - tps.Position).Magnitude
    local ballOffset = hrp.CFrame:ToObjectSpace(tps.CFrame).Position
    
    local forceTake = false

    -- فحص زوايا واسع ومرن يمنع ضياع الكرة عند التفاف الكاميرا يمين/يسار بشكل سريع
    if Configs.Front.Enabled and ballOffset.Z <= 1.5 and mag <= Configs.Front.Value then
        forceTake = true
    elseif Configs.Back.Enabled and ballOffset.Z >= -1.5 and mag <= Configs.Back.Value then
        forceTake = true
    elseif Configs.Side.Enabled and mag <= Configs.Side.Value then
        forceTake = true
    elseif Configs.Head.Enabled and mag <= Configs.Head.Value then
        forceTake = true
    end

    -- تنفيذ السحب الفوري المزدوج (بدون أي تأخير زمني) لضمان سرعة الاستجابة مع الشوت والمراوغة
    if forceTake then
        firetouchinterest(foot, tps, 0)
        firetouchinterest(foot, tps, 1)
        
        -- إرسال لمسة ثانية فورية لضمان أخذ الكرة لاتجاه اللاعب الجديد دون تقطيع
        firetouchinterest(foot, tps, 0)
        firetouchinterest(foot, tps, 1)
    end
end)
